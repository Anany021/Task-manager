# ----- Backend environment -----
# Copy this file to `.env` and fill in real values. NEVER commit `.env` to git.

# Port the server listens on (Railway will override this with its own PORT)
PORT=5000

# Environment: development | production
NODE_ENV=development

# MongoDB connection string (use your Atlas / Compass URI)
# Example Atlas:  mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/taskmanager?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/taskmanager

# JWT signing secret — make this LONG and RANDOM (e.g. `openssl rand -hex 64`)
JWT_SECRET=change_me_to_a_long_random_string

# How long the JWT stays valid (e.g. 7d, 24h)
JWT_EXPIRES_IN=7d

# Origin allowed for CORS (your frontend URL)
# Local dev:        http://localhost:5173
# Railway prod:     https://your-frontend.up.railway.app
CLIENT_URL=http://localhost:5173

# Cookie domain (leave blank for localhost; set on Railway if you serve frontend on a different subdomain)
COOKIE_DOMAIN=
